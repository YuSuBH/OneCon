# ------------------------------
# Root ignore rules (monorepo)
# Frontend: client (Vite)
# Backend: Express (e.g., backend or server)
# ------------------------------

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Dependency directories
node_modules/

# Build outputs
build/
dist/
out/
coverage/

# Environment files
.env
.env.*
!.env.example
!.env.*.example

# OS/editor files
.DS_Store
Thumbs.db
.vscode/
.idea/

# TypeScript
*.tsbuildinfo

# ------------------------------
# Frontend (Vite in client/)
# ------------------------------
client/node_modules/
client/dist/
client/.vite/
client/coverage/

# ------------------------------
# Backend (Express)
# ------------------------------
backend/node_modules/
backend/dist/
backend/build/
backend/coverage/
backend/.env
backend/.env.*

server/node_modules/
server/dist/
server/build/
server/coverage/
server/.env
server/.env.*

# Uploads/temp files often used in Express apps
uploads/
tmp/
temp/
